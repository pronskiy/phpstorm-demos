{
  "name": "jetbrains/PhpStorm_2020.1",
  "description": "PhpStorm 2020.1 Sample Project",
  "homepage": "https://www.jetbrains.com/phpstorm/",
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "JetBrains",
      "email": "phpstorm-support@jetbrains.com"
    }
  ],
  "require": {
    "php": "7.3.*",
    "ext-zip": "*",
    "symfony/console": "^5.0.2",
    "symfony/string": "5.0.3",
    "monolog/monolog": "^2.0.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^8.5.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "App\\Command\\CacheCommand::warm",
      "phpunit tests"
    ],
    "custom-cmd": "App\\Command\\StaticCommand::check"
  }
}
